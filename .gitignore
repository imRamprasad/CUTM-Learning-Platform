# ================================================================================
# Git Ignore Rules for CUTM Learning Platform
# ================================================================================

# ================================================================================
# IDE and Editor Files
# ================================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ================================================================================
# Backend (Java/Maven)
# ================================================================================
target/
classes/
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
.mvn/wrapper/
mvnw.cmd
logs/
*.log

# Maven specific
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
.flattened-pom.xml
.m2/

# ================================================================================
# Frontend (Node.js/React)
# ================================================================================
node_modules/
package-lock.json
yarn.lock
dist/
build/
.env.local
.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/

# ================================================================================
# Environment Variables
# ================================================================================
.env
.env.local
.env.*.local
.env.production.local

# ================================================================================
# OS-specific
# ================================================================================
Thumbs.db
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# ================================================================================
# Database
# ================================================================================
data/
mongodb/
*.db

# ================================================================================
# Build Artifacts
# ================================================================================
bin/
out/
.gradle
build/
*.class
*.jar

# ================================================================================
# Platform-specific
# ================================================================================
# macOS
.DS_Store

# Windows
Thumbs.db
*.lnk

# Linux
.directory

# ================================================================================
# Temporary Files
# ================================================================================
*.tmp
*.bak
*.orig
*~
*.swp
.#*

# ================================================================================
# Testing and Coverage
# ================================================================================
.nyc_output/
coverage/
.coverage
htmlcov/
.pytest_cache/
junit.xml

# ================================================================================
# IDE-specific files not to commit
# ================================================================================
*.iml
*.iws
*.ipr
.idea/
.vscode/
.vim/
.emacs.d/

# ================================================================================
# Docker
# ================================================================================
docker-compose.override.yml
docker-compose.prod.yml

# ================================================================================
# Keep important configuration files
# ================================================================================
!.github/
!.gitignore
!.dockerignore
!pom.xml
!package.json

